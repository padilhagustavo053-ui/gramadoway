# No Streamlit Cloud: Settings → Secrets → cole no formato TOML abaixo.
# Ou use variáveis de ambiente com os mesmos nomes no seu servidor.

# GRAMADOWAY_PLANILHA = "/caminho/absoluto/planilha.xlsx"
# Link direto (HTTPS) a um ficheiro .xlsx público — na Cloud carrega a lista completa sem upload manual:
# GRAMADOWAY_PLANILHA_URL = "https://exemplo.com/planilha-gramadoway.xlsx"
# GRAMADOWAY_DATA_DIR = "/caminho/absoluto/pasta_dados"

# PostgreSQL (Supabase / Neon) — persiste logins, pedidos, clientes e rascunhos na nuvem.
# Supabase: Project Settings → Database → Connection string → URI (use senha da base).
# Preferir conexão direta porta 5432 se o pooler 6543 der erro com o cliente Python.
# GRAMADOWAY_DATABASE_URL = "postgresql://postgres.xxxx:SUASENHA@db.xxxx.supabase.co:5432/postgres"
# SUPABASE_DB_URL = "mesma URI (alias opcional)"
