# Dados sensíveis — não enviar ao Git (exceto README + planilha oficial para a Streamlit Cloud)
# Nota: "data/*.xlsx" + negação falha por vezes no Git; usar data/* + !ficheiro é mais fiável.
data/*
!data/README.txt
!data/planilha.xlsx
data/usuarios/
data/users/
data/.migrated_from_pedidos

# Secrets locais
.streamlit/secrets.toml

# Python
__pycache__/
*.pyc
.pytest_cache/
